        <Marquee height={31} repeatCount={1} animationDuration={120}>
            <div class="flex items-center flex-nowrap gap-2 w-max">
                <FriendButton src={keetsta.src} href="https://keetsta.me" name="keetsta" />
                <FriendButton src={senko.src} href="https://senko.dev" name="senkodev" />
                <FriendButton src={jsopn.src} href="https://jsopn.com/?glunging=true" name="jsopn" />
                <FriendButton src={asya.src} href="https://asyasocute.online" name="asya" />
                <FriendButton src={catboybinary.src} href="https://catboy.page/" name="catboybinary" />
                <FriendButton src={c1oudy.src} href="https://c1oudy.otlegacy.com/" name="c1oudy" />
                <FriendButton src={teidesu.src} href="https://tei.su/" name="alina" />
                <FriendButton src={transmute.src} href="https://std.mem.transmute.me/" name="polina" />
