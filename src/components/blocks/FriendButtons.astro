                <FriendButton src={sapphic.src} href="https://sapphic.moe" name="sapphic angels" />
                <FriendButton src={gapp.src} href="https://gapp.pp.ua" name="gapp" />
                <FriendButton src={pastcard.src} href="https://pastcard.su" name="pastcard" />
                <FriendButton src={milkcool.src} href="https://milkcool.ru/" name="lily" />
